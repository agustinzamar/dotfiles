[user]
	name = {{ .GitName }}
	email = {{ .GitEmail }}
[core]
	autocrlf = input
	pager = delta
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[push]
	autoSetupRemote = true
[help]
	autocorrect = immediate
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
