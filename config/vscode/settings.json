  "chat.editor.fontSize": 14,
  "chat.fontSize": 14,
  "terminal.integrated.fontLigatures.enabled": true,
  "git.allowForcePush": true,
  "gitblame.ignoreWhitespace": true,
  "gitblame.inlineMessageEnabled": true,
  "intelliphp.inlineSuggestionsEnabled": true,
