  "window.confirmSaveUntitledWorkspace": false,
  "window.nativeTabs": true,
  "workbench.editor.enablePreview": false,
  "editor.suggest.preview": true,
  "workbench.browser.showInTitleBar": false,
  "window.restoreFullscreen": true,
  "window.menuStyle": "custom",
  "github.copilot.chat.claudeAgent.allowAutoPermissions": true,
  "github.copilot.chat.anthropic.contextEditing.mode": "clear-both",
  "github.copilot.chat.claude48OpusPrompt.enabled": true,
  "github.copilot.chat.gemini3GetChangedFilesTool.enabled": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "claudeCode.preferredLocation": "panel",
  "workbench.secondarySideBar.showLabels": false,
