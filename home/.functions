function p() {
  if [ -f vendor/bin/pest ]; then
    vendor/bin/pest "$@"
  else
    vendor/bin/phpunit "$@"
  fi
}

function pestf() {
  if [ -f vendor/bin/pest ]; then
    vendor/bin/pest --filter "$@"
  else
    vendor/bin/phpunit --filter "$@"
  fi
}

function pestp() {
  php artisan test --parallel "$@"
}

function mkd() {
  mkdir -p "$@" && cd "$_"
}

function digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}

function git-prune-local() {
  git fetch -p && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -D
}

function removebg() {
  local input="$1"
  local dir="$(dirname "$input")"
  local base="$(basename "$input")"
  local name="${base%.*}"
  local ext="${base##*.}"
  if [ "$name" = "$ext" ]; then
    rembg i "$input" "$dir/${name}_no_bg"
  else
    rembg i "$input" "$dir/${name}_no_bg.${ext}"
  fi
}

function clone() {
  if [ $# -eq 0 ]; then
    local repo=$(gh api "user/repos?per_page=200&type=all" --jq '.[].full_name' 2>/dev/null | fzf --prompt="Clone repo: ")
    [ -n "$repo" ] && gh repo clone "$repo"
  else
    gh repo clone "$1" "${@:2}"
  fi
}
